//  iBUS RC INPUT
// ════════════════════════════════════════════════════════════════════
RCState rc;

static uint8_t  ib_buf[32];
static uint8_t  ib_idx     = 0;
static bool     ib_synced  = false;
static uint32_t ib_lastMs  = 0;
static bool     ib_prevArm = false;

float applyDeadband(float v, float db) {
  if (fabsf(v) < db) return 0.0f;
  return (v > 0.0f) ? (v - db) / (1.0f - db) : (v + db) / (1.0f - db);
}

void updateIBUS() {
  while (Serial1.available()) {
    uint8_t b = Serial1.read();

    if (!ib_synced) {
      if (b == 0x20) { ib_buf[0] = b; ib_idx = 1; ib_synced = true; }
      continue;
    }

    ib_buf[ib_idx++] = b;

    if (ib_idx == 2 && b != 0x40) { ib_synced = false; ib_idx = 0; continue; }
    if (ib_idx < 32) continue;

    ib_synced = false; ib_idx = 0;

    uint16_t chk = 0xFFFF;
    for (int i = 0; i < 30; i++) chk -= ib_buf[i];
    if (chk != (ib_buf[30] | ((uint16_t)ib_buf[31] << 8))) continue;

    for (int i = 0; i < 10; i++)
      rc.ch[i] = ib_buf[2 + i*2] | ((uint16_t)ib_buf[3 + i*2] << 8);

    ib_lastMs = millis();
  }

  rc.signalLost = (millis() - ib_lastMs > 500);
  if (rc.signalLost) {
    rc.throttle = 0.0f; rc.roll = 0.0f; rc.pitch = 0.0f; rc.yaw = 0.0f;
    rc.armed    = false;
    return;
  }

  rc.roll     = applyDeadband(constrain((float)(rc.ch[0]-1500)/500.f, -1.f, 1.f), 0.05f);
  rc.pitch    = applyDeadband(constrain((float)(rc.ch[1]-1500)/500.f, -1.f, 1.f), 0.05f);
  rc.throttle = constrain((float)(rc.ch[2]-1000)/1000.f, 0.f, 1.f);
  rc.yaw      = applyDeadband(constrain((float)(rc.ch[3]-1500)/500.f, -1.f, 1.f), 0.05f);

  bool armSw = (rc.ch[4] < 1300);
  if (armSw && !ib_prevArm && rc.ch[2] < 1100) rc.armed = true; 
  if (!armSw)                                  rc.armed = false;
  ib_prevArm = armSw;
}

