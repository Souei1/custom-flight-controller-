// ════════════════════════════════════════════════════════════════════
//  PID FUNCTIONS
// ════════════════════════════════════════════════════════════════════
float pid_calc_rate(float error, float rate, float dt, float kp, float ki, float kd, PIDSTATE *state) {
  if (fabsf(error) < 0.3f) {
    state->i += error * dt;
    state->i  = constrain(state->i, -4.0f, 4.0f);
  }
  float d_raw = (rate - state->prev_rate) / dt;
  float d = 0.9f * state->prev_d + 0.1f * d_raw;
  state->prev_d = d;
  state->prev_rate = rate;
  state->prev_error = error;
  return kp * error + ki * state->i - kd * d;
}

float pid_calc(float error, float angle, float rate, float dt, float kp, float ki, float kd, PIDSTATE_ANGLE *state) {
  if (fabsf(error) < 15.0f) {
    state->i += error * dt;
    state->i  = constrain(state->i, -4.0f, 4.0f);
  }
  float d = rate;
  state->prev_error = error;
  return kp * error + ki * state->i - kd * d;
}

// ════════════════════════════════════════════════════════════════════
//  MOTOR MIXER (Full X-Frame 4-Motor Mix)
// ════════════════════════════════════════════════════════════════════
void motor_mixer(float roll_out, float pitch_out, float yaw_out, float *m0, float *m1, float *m2, float *m3) {
  *m0 = base_pwm + roll_out + pitch_out + yaw_out;
  *m1 = base_pwm - roll_out + pitch_out - yaw_out;
  *m2 = base_pwm - roll_out - pitch_out + yaw_out;
  *m3 = base_pwm + roll_out - pitch_out - yaw_out;

  // Rescale if any motor saturates, preserving relative ratios
  float max_pwm = max(max(*m0, *m1), max(*m2, *m3));
  float min_pwm = min(min(*m0, *m1), min(*m2, *m3));

  if (max_pwm > 1800.0f) {
    float excess = max_pwm - 1800.0f;
    *m0 -= excess; *m1 -= excess; *m2 -= excess; *m3 -= excess;
  }
  if (min_pwm < 1050.0f) {
    float deficit = 1050.0f - min_pwm;
    *m0 += deficit; *m1 += deficit; *m2 += deficit; *m3 += deficit;
  }

  int motorCommand1 = map(*m0, 1000, 2000, 1843, 3686);
  int motorCommand2 = map(*m1, 1000, 2000, 1843, 3686);
  int motorCommand3 = map(*m2, 1000, 2000, 1843, 3686);
  int motorCommand4 = map(*m3, 1000, 2000, 1843, 3686);

  analogWrite(motorPin[0], motorCommand1);
  analogWrite(motorPin[1], motorCommand2);
  analogWrite(motorPin[2], motorCommand3);
  analogWrite(motorPin[3], motorCommand4);
}

void motorsOff() {
  analogWrite(motorPin[0], 1843);
  analogWrite(motorPin[1], 1843);
  analogWrite(motorPin[2], 1843);
  analogWrite(motorPin[3], 1843);
}

