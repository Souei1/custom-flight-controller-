//-----------------------gyro bias--------------------------------
void calibrateGyro(int samples=500, int delayMs=5) {
  long gx_sum=0, gy_sum=0, gz_sum=0;
  for (int i=0;i<samples;i++){
    float ax,ay,az, gx,gy,gz;
    if (!readMPU(ax,ay,az,gx,gy,gz)) { delay(5); --i; continue; }
    gx_sum += (long)(gx * 1e6f); // scale to preserve precision
    gy_sum += (long)(gy * 1e6f);
    gz_sum += (long)(gz * 1e6f);
    delay(delayMs);
  }
  gyro_x_bias = (float)gx_sum / (samples * 1e6f);
  gyro_y_bias = (float)gy_sum / (samples * 1e6f);
  gyro_z_bias = (float)gz_sum / (samples * 1e6f);

  Serial.print("Gyro biases (rad/s): ");
  Serial.print(gyro_x_bias,6); Serial.print(", ");
  Serial.print(gyro_y_bias,6); Serial.print(", ");
  Serial.println(gyro_z_bias,6);
}
// -------------------------- helper functions --------------------------
void normalizeVec3(float &x, float &y, float &z) {
  float n = sqrtf(x*x + y*y + z*z);
  if (n > 1e-8f) {
    x /= n; y /= n; z /= n;
  } else {
    // fallback to avoid division by zero: point Z-up
    x = 0.0f; y = 0.0f; z = 1.0f;
  }
}
