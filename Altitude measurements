void setupMPU6050() {
  Wire1.begin();                // use default SDA/SCL pins on Teensy
  Wire1.setClock(I2C_Freq);     // set 400kHz bus speed

  Wire1.beginTransmission(ADDR_MPU);
  Wire1.write(0x6B); Wire1.write(0x00);
  Wire1.endTransmission();

  Wire1.beginTransmission(ADDR_MPU);
  Wire1.write(0x1C); Wire1.write(0x10);
  Wire1.endTransmission();

  Wire1.beginTransmission(ADDR_MPU);
  Wire1.write(0x1B); Wire1.write(0x18);
  Wire1.endTransmission();
}

void setupQMC() {
  // QMC5883L init: control register set to continuous, 200Hz, 8G, OSR 512 -> 0x59
  Wire1.begin();                // use default SDA/SCL pins on Teensy
  Wire1.setClock(I2C_Freq);     // set 400kHz bus speed

  Wire1.beginTransmission(ADDR_MAG);
  Wire1.write(0x0B); Wire1.write(0x01);
  Wire1.endTransmission();

  Wire1.beginTransmission(ADDR_MAG);
  Wire1.write(0x09); Wire1.write(0x59);
  Wire1.endTransmission();
}
