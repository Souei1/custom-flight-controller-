//-----------------------barometer---------------------------
void setupBMP280() {
  Wire.begin();
  Wire.setClock(I2C_Freq);
  // Initialize BMP280
  Wire.beginTransmission(BMP280_ADDR);
  Wire.write(0xF4); // ctrl_meas register
  Wire.write(0x33); // osr_p=x8, osr_t=x1, normal mode
  Wire.endTransmission();
  
  Wire.beginTransmission(BMP280_ADDR);
  Wire.write(0xF5); // config register
  Wire.write(0x08); // t_sb=0.5ms, filter=4
  Wire.endTransmission();

  // Read calibration data (only need to do this once)
  readCalibrationData();
}

void readCalibrationData() {
  uint8_t calib_data[24];
  
  Wire.beginTransmission(BMP280_ADDR);
  Wire.write(0x88); // Start at first calibration register
  Wire.endTransmission(false);

  Wire.requestFrom(BMP280_ADDR, 24);
  for (int i = 0; i < 24; i++) {
    calib_data[i] = Wire.read();
  }

  // Parse calibration data (little-endian)
  calib.dig_T1 = (calib_data[1] << 8) | calib_data[0];
  calib.dig_T2 = (calib_data[3] << 8) | calib_data[2];
  calib.dig_T3 = (calib_data[5] << 8) | calib_data[4];
  calib.dig_P1 = (calib_data[7] << 8) | calib_data[6];
  calib.dig_P2 = (calib_data[9] << 8) | calib_data[8];
  calib.dig_P3 = (calib_data[11] << 8) | calib_data[10];
  calib.dig_P4 = (calib_data[13] << 8) | calib_data[12];
  calib.dig_P5 = (calib_data[15] << 8) | calib_data[14];
  calib.dig_P6 = (calib_data[17] << 8) | calib_data[16];
  calib.dig_P7 = (calib_data[19] << 8) | calib_data[18];
  calib.dig_P8 = (calib_data[21] << 8) | calib_data[20];
  calib.dig_P9 = (calib_data[23] << 8) | calib_data[22];
}

void readSensorData(float *temperature, float *pressure) {
  uint8_t data[6];
  
  // Read pressure and temperature data
  Wire.beginTransmission(BMP280_ADDR);
  Wire.write(0xF7); // pressure_msb register
  Wire.endTransmission(false);
  
  Wire.requestFrom(BMP280_ADDR, 6);
  for (int i = 0; i < 6; i++) {
    data[i] = Wire.read();
  }

  // Combine bytes (note correct order: data[0]=msb, data[1]=lsb, data[2]=xlsb)
  int32_t raw_temp = (data[3] << 12) | (data[4] << 4) | (data[5] >> 4);
  int32_t raw_pres = (data[0] << 12) | (data[1] << 4) | (data[2] >> 4);

  // Temperature compensation
  int32_t var1 = ((((raw_temp >> 3) - ((int32_t)calib.dig_T1 << 1))) * ((int32_t)calib.dig_T2)) >> 11;
  int32_t var2 = (((((raw_temp >> 4) - ((int32_t)calib.dig_T1)) * ((raw_temp >> 4) - ((int32_t)calib.dig_T1))) >> 12) * ((int32_t)calib.dig_T3)) >> 14;
  int32_t t_fine = var1 + var2;
  *temperature = (float)t_fine / 5120.0;

  // Pressure compensation
  int64_t var3, var4, p;
  var3 = ((int64_t)t_fine) - 128000;
  var4 = var3 * var3 * (int64_t)calib.dig_P6;
  var4 = var4 + ((var3 * (int64_t)calib.dig_P5) << 17);
  var4 = var4 + (((int64_t)calib.dig_P4) << 35);
  var3 = ((var3 * var3 * (int64_t)calib.dig_P3) >> 8) + ((var3 * (int64_t)calib.dig_P2) << 12);
  var3 = (((((int64_t)1) << 47) + var3)) * ((int64_t)calib.dig_P1) >> 33;
  
  if (var3 == 0) {
    *pressure = 0; // Avoid division by zero
  } else {
    p = 1048576 - raw_pres;
    p = (((p << 31) - var4) * 3125) / var3;
    var3 = (((int64_t)calib.dig_P9) * (p >> 13) * (p >> 13)) >> 25;
    var4 = (((int64_t)calib.dig_P8) * p) >> 19;
    p = ((p + var3 + var4) >> 8) + (((int64_t)calib.dig_P7) << 4);
    *pressure = (float)p / 256; // Convert to hPa
  }
  
}

void setup() {
  Serial.begin(115200);
  setupMPU6050();
  delay(5) ; 
  GPSserial.begin(38400); // RX=16, TX=17 on ESP32
  delay(5);
  setupBMP280() ;
  delay(5);
  delay(5);
  calibrateGyro(500, 5);
  prevLoopTime = micros();
  prevLoopTime_rate = micros();
  Serial.println("Send base_pwm over serial (e.g. 1300) to arm.");
}

void loop() {

  // ── serial input ──
  if (Serial.available()) {
    float val = Serial.parseFloat();
    flag = val; 
    if (val >= 1000.0f && val <= 2000.0f) {
      base_pwm = val;
      running  = (val >= 1050.0f);
      flag_kill = false;
      Serial.print("base_pwm set to: "); Serial.println(base_pwm);
    }
  }

  // ── fixed rate gate ──
  unsigned long now = micros();
  if (now - prevLoopTime_rate >= LOOP_PERIOD_US_RATE){ 
    flag1 = 1; 
    dt1 = (now - prevLoopTime_rate) * 1e-6f;
    prevLoopTime_rate = now;
  }
  //--fixed angle gate --
  if (now - prevLoopTime >= LOOP_PERIOD_US){ 
    flag2 = 1; 
    dt2 = (now - prevLoopTime) * 1e-6f;
    prevLoopTime = now;
  }
  //-fixed position gate--
  if (now - prevLoopTime_angle >= LOOP_PERIOD_US_angle){ 
    flag3 = 1; 
    dt3 = (now - prevLoopTime_angle) * 1e-6f;
    prevLoopTime_angle = now;
  }
  
  if(now - prevLoopTime_sec >= 60000000){
    Serial.print("accelx: "); Serial.print(ax_average/counter1); 
    Serial.print("  accely: ");Serial.print(ay_average/counter1);
    Serial.print("  accelz: ");Serial.print(az_average/counter1);
    Serial.print("  gpsx: ");Serial.print(gpsx_average/counter2);
    Serial.print("  gpsy: ");Serial.print(gpsy_average/counter2);
    Serial.print("  gpsz: ");Serial.print(gpsz_average/counter2);
    Serial.print("  baro: ");Serial.println(baro_average/counter3);
    flag = -1 ; 
  }

  if(flag > 1){

  // ── kill switch ──
    if (flag_kill || !running) {
    for (int i = 0; i < NUM_MOTORS; i++)
      esc[i].writeMicroseconds(1000);
    return;
    }

    if(flag1){
      flag1 = 0 ; 

      // ── read IMU ──
      bool ok1 = readMPU(ax, ay, az, wx, wy, wz);

      float q0 = q[0], q1 = q[1], q2 = q[2], q3 = q[3];

      // DCM rows: body → world   (v_world = R * v_body)
      float Rxx = 1.0f - 2.0f*(q2*q2 + q3*q3);
      float Rxy = 2.0f*(q1*q2 - q0*q3);
      float Rxz = 2.0f*(q1*q3 + q0*q2);

      float Ryx = 2.0f*(q1*q2 + q0*q3);
      float Ryy = 1.0f - 2.0f*(q1*q1 + q3*q3);
      float Ryz = 2.0f*(q2*q3 - q0*q1);

      float Rzx = 2.0f*(q1*q3 - q0*q2);
      float Rzy = 2.0f*(q2*q3 + q0*q1);
      float Rzz = 1.0f - 2.0f*(q1*q1 + q2*q2);

      a_x =   Rxx*ax + Rxy*ay + Rxz*az;
      a_y =   Ryx*ax + Ryy*ay + Ryz*az;
      a_z = -(Rzx*ax + Rzy*ay + Rzz*az - 9.81f);  // remove gravity on world-Z

      ax_f = ax_prev*accel_alpha + (1.0f-accel_alpha)*a_x;
      ay_f = ay_prev*accel_alpha + (1.0f-accel_alpha)*a_y;
      az_f = az_prev*accel_alpha + (1.0f-accel_alpha)*a_z;

      ax_prev=ax_f; ay_prev=ay_f; az_prev=az_f;

      ax_average += ax_f*ax_f ; 
      ay_average += ay_f*ay_f ; 
      az_average += az_f*az_f ; 
      counter1++; 

      bool ok2 = readMag(mx_read, my_read, mz_read, magBias, magScale);
      if (!ok2) {
       Serial.println("MAG read failed");
       delay(50);
        return;
      }
      if (!ok1) {
        Serial.println("MPU read failed");
        return;
      }
    
      // ── low-pass filter ──
      wx_f = gyro_alpha * gx_prev + (1.0f - gyro_alpha) * wx;
      wy_f = gyro_alpha * gy_prev + (1.0f - gyro_alpha) * wy;
      wz_f = gyro_alpha * gz_prev + (1.0f - gyro_alpha) * wz;
      gx_prev = wx_f; gy_prev = wy_f; gz_prev = wz_f;

      mx_read_f = mx_read_prev * gyro_alpha + (1.0f-gyro_alpha) * mx_read;
      my_read_f = my_read_prev * gyro_alpha + (1.0f-gyro_alpha) * my_read;
      mz_read_f = mz_read_prev * gyro_alpha + (1.0f-gyro_alpha) * mz_read;
      mx_read_prev = mx_read_f; my_read_prev = my_read_f; mz_read_prev = mz_read_f;

      // ── safety cutoff ──
      if (fabsf(wx_f) > 20.0f || fabsf(wy_f) > 20.0f) {
        Serial.print("RATE LIMIT HIT — killing motors"); Serial.print("  ");
        Serial.print("wx:  ");Serial.print(wx_f);Serial.print("wy: ");Serial.println(wy_f);   
        flag_kill = true;
        return;
      }

    }
    if(flag2){
      flag2 = 0 ;

      float ax_m = ax;   // body X (forward)  <= raw Ay
      float ay_m = ay;   // body Y (right)    <= raw Ax
      float az_m = az;   // body Z (down)     <= -raw Az  (flip Z)

      normalizeVec3(ax_m, ay_m, az_m);
      float mx_n = my_read_f, my_n = -mx_read_f, mz_n = mz_read_f;
      normalizeVec3(mx_n, my_n, mz_n);
      MadgwickAHRSupdateIMU(wx_f, wy_f, wz_f, ax_m, ay_m, az_m, dt2) ; 
      MadgwickAHRSupdate(wx_f, wy_f, wz_f, ax_m, ay_m, az_m, mx_n, my_n,  mz_n,dt2);
    
      quatToEuler(q[0], q[1], q[2], q[3], &pitch_f, &roll_f, &yaw_f);
      quatToEuler(q_1[0], q_1[1], q_1[2], q_1[3], &pitch_f_2, &roll_f_2, &yaw_f_2);
    
      if(once == false){
        once = true ; 
        roll_init  = roll_f  ;
        pitch_init = pitch_f ;  
      }
      roll_f  -= (roll_init)  ; 
      pitch_f -= (pitch_init) ;
    
    }
    if(flag3){
      flag3 = 0; 

      while (GPSserial.available()) {
         gps.encode(GPSserial.read());
      }
      if (gps.location.isUpdated() && gps.location.isValid()) {

        if(once1 == true ){
          lat_once = gps.location.lat() ; 
          lng_once = gps.location.lng() ; 
          alt_once = gps.altitude.meters() ;
          once1 = false ; 
        }
        alt_m = (gps.altitude.meters() - alt_once);
        double dLat = (gps.location.lat() - lat_once) * PI / 180.0;
        double dLon = (gps.location.lng() - lng_once) * PI / 180.0;

        y = dLat * R;
        x = dLon * R * cos( lat_once* PI / 180.0);
        
        gpsx_average += alt_m*alt_m ; 
        gpsy_average += x*x ; 
        gpsx_average += y*y ; 
        counter2++; 
      }

      float temperature, pressure ; 
      // Read raw data
      readSensorData(&temperature, &pressure);
    
      float pres_f = pressure ; 
      pres_f /= 100;
      float pressure_rounded = round(pres_f * 100) / 100;
     
      // Set ground reference pressure on first reading
      if (first_reading) {
        p_int = pressure_rounded;
        first_reading = false; 
      }

      height = 44330 * (1.0 - pow(pressure_rounded/p_int, 0.1903));
      height_f = height_prev*height_alpha + (1.0 - height_alpha)*height ; 
      height_prev = height_f ; 
      
      baro_average += height_f*height_f ; 
      counter3++; 

      kf_alt(a_z,  alt_m ,height, dt, &xk , &vk, &ak, &P11  , &P12 , &P13  , &P21  , &P22  , &P23   ,&P31  , &P32 , &P33  );
      kf(a_y,  x , dt, &xk1 , &vk1, &ak1, &P11_1  , &P12_1 , &P13_1  , &P21_1  , &P22_1  , &P23_1   ,&P31_1  , &P32_1 , &P33_1  );
      kf(a_x,  y , dt, &xk2 , &vk2, &ak2, &P11_2  , &P12_2 , &P13_2  , &P21_2  , &P22_2  , &P23_2   ,&P31_2  , &P32_2 , &P33_2  );
      
      Serial.println(height_f) ; 
      Serial.print(" x_GPS: "); Serial.print(x); Serial.print(" xa: "); Serial.print(ay_f); Serial.print(" X: "); Serial.println(xk2);
      Serial.print(" y_GPS: "); Serial.print(y); Serial.print(" ya: "); Serial.print(ax_f); Serial.print(" Y : "); Serial.println(xk1);
      Serial.print(" ALT: "); Serial.print(alt_m); Serial.print("  ALT_a: "); Serial.print(az_f); Serial.print(" ALT: "); Serial.println(xk);
      Serial.println();

    }

  }
