// -------------------------- read functions --------------------------
// Returns: true when read succeeded, false on timeout/short read
// Outputs:
//  ax,ay,az => accel in m/s^2 (bias-subtracted if accel_x_bias set)
//  wx,wy,wz => gyro in rad/s (bias-subtracted if gyro_*_bias set)
bool readMPU(float &ax, float &ay, float &az, float &wx, float &wy, float &wz) {
  Wire1.beginTransmission(ADDR_MPU);
  Wire1.write(0x3B);
  Wire1.endTransmission(false);

  uint8_t count = Wire1.requestFrom(ADDR_MPU, (uint8_t)14);
  if (count < 14) return false;

  int16_t rawAx = (int16_t)(Wire1.read() << 8 | Wire1.read());
  int16_t rawAy = (int16_t)(Wire1.read() << 8 | Wire1.read());
  int16_t rawAz = (int16_t)(Wire1.read() << 8 | Wire1.read());
  int16_t rawTemp = (int16_t)(Wire1.read() << 8 | Wire1.read()); (void)rawTemp;
  int16_t rawGx = (int16_t)(Wire1.read() << 8 | Wire1.read());
  int16_t rawGy = (int16_t)(Wire1.read() << 8 | Wire1.read());
  int16_t rawGz = (int16_t)(Wire1.read() << 8 | Wire1.read());

  // scale accel: raw / (LSB per g) -> g -> *9.80665 -> m/s^2
  ax = ( (float)rawAx / ACCEL_SENS ) * G_TO_MS2;
  ay = ( (float)rawAy / ACCEL_SENS ) * G_TO_MS2;
  az = ( (float)rawAz / ACCEL_SENS ) * G_TO_MS2;
  
  // subtract any precomputed bias (in same units)
  ax -= accel_x_bias;
  ay -= accel_y_bias;
  az -= accel_z_bias;

  // scale gyro: raw / LSB -> deg/s -> *DEG2RAD -> rad/s
  wx = ( (float) rawGx / GYRO_SENS ) * DEG2RAD;
  wy = ( (float) rawGy / GYRO_SENS ) * DEG2RAD;
  wz = ( (float) rawGz / GYRO_SENS ) * DEG2RAD;

  wx -= gyro_x_bias;
  wy -= gyro_y_bias;
  wz -= gyro_z_bias;
   

  return true;
}
bool readMag(float &mx, float &my, float &mz,float *magBias , float *magScale) {
  Wire1.beginTransmission(ADDR_MAG);
  Wire1.write(0x00);
  Wire1.endTransmission(false);
  
  uint8_t count = Wire1.requestFrom(ADDR_MAG, (uint8_t)6);
  if (count < 6) return false;

  uint8_t xl = Wire1.read();
  uint8_t xh = Wire1.read();
  uint8_t yl = Wire1.read();
  uint8_t yh = Wire1.read();
  uint8_t zl = Wire1.read();
  uint8_t zh = Wire1.read();

  int16_t rawX = (int16_t)((xh << 8) | xl);
  int16_t rawY = (int16_t)((yh << 8) | yl);
  int16_t rawZ = (int16_t)((zh << 8) | zl);

  // Soft-iron correction (3x3 matrix)
  float x_corr = (rawX - magBias[0]) * magScale[0];
  float y_corr = (rawY - magBias[1]) * magScale[1];
  float z_corr = (rawZ - magBias[2]) * magScale[2];

  mx = x_corr;
  my = y_corr;
  mz = z_corr;

  return true;
}

void iron_calib(){
  Serial.println("Rotate IMU in full sphere... collecting data...");
  float mxMin = 1e6, mxMax = -1e6;
  float myMin = 1e6, myMax = -1e6;
  float mzMin = 1e6, mzMax = -1e6;
  float magx = 0.0;
  float magy = 0.0;
  float magz = 0.0;
  for(int i=0; i<CALIB_SAMPLES; i++){
    readMag(magx,magy,magz); // You already have this function
    if(magx < mxMin) mxMin = magx;
    if(magx > mxMax) mxMax = magx;
    if(magy < myMin) myMin = magy;
    if(magy > myMax) myMax = magy;
    if(magz < mzMin) mzMin = magz;
    if(magz > mzMax) mzMax = magz;

    Serial.print(i);
    delay(50);
  }
  Serial.println(); 
  magBias[0] = (mxMax + mxMin) / 2.0;
  magBias[1] = (myMax + myMin) / 2.0;
  magBias[2] = (mzMax + mzMin) / 2.0;

  magScale[0] = (mxMax - mxMin) / 2.0;
  magScale[1] = (myMax - myMin) / 2.0;
  magScale[2] = (mzMax - mzMin) / 2.0;

  // Normalize scale
  float avg = (magScale[0] + magScale[1] + magScale[2]) / 3.0;
  magScale[0] = avg / magScale[0];
  magScale[1] = avg / magScale[1];
  magScale[2] = avg / magScale[2];
}

