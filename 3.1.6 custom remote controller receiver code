#include <SPI.h>

#define CE_PIN  6
#define CSN_PIN 10

struct DataPackage {
  int16_t throttle;
  int16_t pitch;
  int16_t roll;
  int16_t yaw;
};

DataPackage myData;
byte address[5] = {'D','R','O','N','E'};
unsigned long lastSignalTime = 0;
uint32_t packetCount = 0;

byte readRegister(byte reg) {
  digitalWrite(CSN_PIN, LOW);
  SPI.transfer(reg);
  byte val = SPI.transfer(0x00);
  digitalWrite(CSN_PIN, HIGH);
  return val;
}

void writeRegister(byte reg, byte val) {
  digitalWrite(CSN_PIN, LOW);
  SPI.transfer(0x20 | reg);
  SPI.transfer(val);
  digitalWrite(CSN_PIN, HIGH);
}

void writeRegisterMulti(byte reg, byte* buf, byte len) {
  digitalWrite(CSN_PIN, LOW);
  SPI.transfer(0x20 | reg);
  for (byte i = 0; i < len; i++) SPI.transfer(buf[i]);
  digitalWrite(CSN_PIN, HIGH);
}

void command(byte cmd) {
  digitalWrite(CSN_PIN, LOW);
  SPI.transfer(cmd);
  digitalWrite(CSN_PIN, HIGH);
}

void setup() {
  Serial.begin(115200);
  Serial.println("=== RADIO RECEIVER ONLY ===");

  SPI.begin();
  pinMode(CE_PIN, OUTPUT);
  pinMode(CSN_PIN, OUTPUT);
  digitalWrite(CE_PIN, LOW);
  digitalWrite(CSN_PIN, HIGH);

  writeRegister(0x00, 0x0B);             
  writeRegister(0x01, 0x01);             
  writeRegister(0x03, 0x03);             
  writeRegister(0x04, 0x03);             
  writeRegister(0x05, 110);              
  writeRegister(0x06, 0x07);             
  writeRegister(0x11, sizeof(myData));   
  writeRegisterMulti(0x0A, address, 5);  

  command(0xE2);                         
  writeRegister(0x07, 0x70);             
  digitalWrite(CE_PIN, HIGH);

  byte cfg = readRegister(0x00);
  Serial.print("RX CONFIG: 0x"); Serial.println(cfg, HEX);
  if (cfg == 0x0B) Serial.println("nRF24 RX OK");
  else Serial.println("nRF24 RX ERROR – check wiring & 3.3V power!");
  
  lastSignalTime = millis();
}

void loop() {
 
  byte status = readRegister(0x07);
  if (status & 0x40) {                    
    lastSignalTime = millis();
    packetCount++;
    digitalWrite(CSN_PIN, LOW);
    SPI.transfer(0x61);                     
    byte* ptr = (byte*)&myData;
    for (int i = 0; i < sizeof(myData); i++) {
      ptr[i] = SPI.transfer(0x00);
    }
    digitalWrite(CSN_PIN, HIGH);
    writeRegister(0x07, 0x40);             
    
    
    Serial.print("Packets: "); Serial.print(packetCount);
    Serial.print(" | Throttle: "); Serial.print(myData.throttle);
    Serial.print(" Pitch: "); Serial.print(myData.pitch);
    Serial.print(" Roll: "); Serial.print(myData.roll);
    Serial.print(" Yaw: "); Serial.println(myData.yaw);
  }

  
  if (millis() - lastSignalTime > 500) {
    
  }
}
