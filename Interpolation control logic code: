void setup(){ 
  Serial.begin(115200); 
  setupMPU6050();
  setupQMC5883L(); 
  Serial.println("Calibrating gyro... Keep IMU steady!");
  delay(5);
  calibrateGyro(500, 5);
  Serial.println("Calibration complete.");
  delay(100);
   if (readMPU(ax, ay, az, wx, wy, wz)) {

    float ax_m = ay;
    float ay_m = ax;
    float az_m = az;

    normalizeVec3(ax_m, ay_m, az_m);

    float roll0  = atan2f(ay_m, az_m);
    float pitch0 = atan2f(-ax_m, sqrtf(ay_m * ay_m + az_m * az_m));

    float cr = cosf(roll0 * 0.5f);
    float sr = sinf(roll0 * 0.5f);
    float cp = cosf(pitch0 * 0.5f);
    float sp = sinf(pitch0 * 0.5f);

    q[0] = cr * cp;
    q[1] = sr * cp;
    q[2] = cr * sp;
    q[3] = -sr * sp;

    float n = sqrtf(q[0]*q[0] + q[1]*q[1] + q[2]*q[2] + q[3]*q[3]);

    if (n > 1e-8f) {
      q[0] /= n;
      q[1] /= n;
      q[2] /= n;
      q[3] /= n;
    }
  }
  esc1.attach(23, 1000, 2000);   
  esc1.writeMicroseconds(1000); 
  esc2.attach(14, 1000, 2000);   
  esc2.writeMicroseconds(1000); 
  esc3.attach(9, 1000, 2000);   
  esc3.writeMicroseconds(1000); 
  esc4.attach(0, 1000, 2000);   
  esc4.writeMicroseconds(1000); 
  Serial.println("Ready.");
  delay(10000); 
  Serial.println("will start");
  delay(5000);
   prevLoopTime_rate = micros();
  prevLoopTime = micros();
} 
void loop(){
  if (Serial.available() > 0) {
    char cmd = Serial.read();
   if (cmd == 'k' || cmd == 'K') {
      esc1.writeMicroseconds(1000);
      esc2.writeMicroseconds(1000);
      esc3.writeMicroseconds(1000);
      esc4.writeMicroseconds(1000);
      flag3 = true; 
      Serial.println("=== All motors stopped ===");
    } 
  }
   unsigned long now = micros();

  if (now - prevLoopTime_rate >= LOOP_PERIOD_US_RATE) {
    flag1 = true;
    dt1 = (now - prevLoopTime_rate) * 1e-6f;
    prevLoopTime_rate = now;
  }

  if (now - prevLoopTime >= LOOP_PERIOD_US) {
    flag2 = true;
    dt2 = (now - prevLoopTime) * 1e-6f;
    prevLoopTime = now;
  }
  //--- inner loop
  if (flag1) {
    flag1 = false;

    bool ok1 = readMPU(ax, ay, az, wx, wy, wz);

    if (!ok1) {
      Serial.println("MPU read failed");
      return;
    }

    // Gyro LPF
    wx_f = gyro_alpha * gx_prev + (1.0f - gyro_alpha) * wx;
    wy_f = gyro_alpha * gy_prev + (1.0f - gyro_alpha) * wy;
    wz_f = gyro_alpha * gz_prev + (1.0f - gyro_alpha) * wz;

    gx_prev = wx_f;
    gy_prev = wy_f;
    gz_prev = wz_f;

    
    if ((wy_f >= 5.0f || wy_f <= -5.0f) && flag3 == false) {
      Serial.print("roll_rate limit hit: ");
      Serial.println(wy_f);

      esc1.writeMicroseconds(1000);
      esc2.writeMicroseconds(1000);
      esc3.writeMicroseconds(1000);
      esc4.writeMicroseconds(1000);

      flag3 = true;
    }

    if (flag3 == false) {

      // roll rate error
      roll_error = roll_rate_ref - wy_f;
      pitch_error = pitch_rate_ref - wx_f ; 
      yaw_error =  yaw_rate_ref - wz_f;
      // inner PID output = torque
      roll_torque = pid(roll_error, dt1, kp, ki, kd, &diff,&pid_roll_rate);
      pitch_torque = pid(pitch_error, dt1, kp_pitch_rate, ki_pitch_rate, kd_pitch_rate, &diff,&pid_pitch_rate) ; 

      float T = 6.0f;

      vin = v_ref;

      F1 = T / 4.0f + roll_torque + pitch_torque - yaw_torque;
      F2 = T / 4.0f - roll_torque + pitch_torque + yaw_torque;
      F3 = T / 4.0f - roll_torque - pitch_torque - yaw_torque;
      F4 = T / 4.0f + roll_torque - pitch_torque + yaw_torque;

      F1 = constrain(F1 * (v_ref / vin), 0, 7);
      F2 = constrain(F2 * (v_ref / vin), 0, 7);
      F3 = constrain(F3 * (v_ref / vin), 0, 7);
      F4 = constrain(F4 * (v_ref / vin), 0, 7);

      pwm1 = constrain(cubicInterp_C2(F1),  1050, 1300);
      pwm2 = constrain(cubicInterp_CC2(F2), 1050, 1300);
      pwm3 = constrain(cubicInterp_CC1(F3), 1050, 1300);
      pwm4 = constrain(cubicInterp_C1(F4),  1050, 1300);

      esc1.writeMicroseconds(pwm1);
      esc2.writeMicroseconds(pwm2);
      esc3.writeMicroseconds(pwm3);
      esc4.writeMicroseconds(pwm4);
    }
  }
   if (flag2) {
    flag2 = false;

    float ax_m = ay;
    float ay_m = ax;
    float az_m = az;

    bool mag_ok = readQMC5883L(mx, my, mz);
    if (!mag_ok) { mx = 0.0f; my = 0.0f; mz = 0.0f; } 
   float mx_m = my;
   float my_m = mx;
   float mz_m = mz;

    normalizeVec3(ax_m, ay_m, az_m);

    MadgwickAHRSupdate(wx_f, wy_f, wz_f,
                   ax_m, ay_m, az_m,
                   mx_m, my_m, mz_m,
                   dt2);

    quatToFusedAngles(q[0], q[1], q[2], q[3],
                      &yaw_f, &pitch_f, &roll_f);

    if (angle_once == false) {
      angle_once = true;
      roll_init = roll_f;
      pitch_init = pitch_f;
      yaw_init = yaw_f;
    }

    roll_f -= roll_init;
    pitch_f -= pitch_init;
    yaw_f -= yaw_init;

  
    roll_rate_ref = pid_calc(roll_ref - roll_f,roll_f,wy_f,dt2,kp_roll,ki_roll,kd_roll,&pid_roll);
    roll_rate_ref = constrain(roll_rate_ref, -1.5f, 1.5f); 
    pitch_rate_ref = pid_calc(pitch_ref - pitch_f,pitch_f,wx_f,dt2,kp_pitch,ki_pitch,kd_pitch,&pid_pitch);
    pitch_rate_ref = constrain(pitch_rate_ref, -1.5f, 1.5f); 
    yaw_rate_ref = pid_calc(yaw_ref - yaw_f, yaw_f, wz_f, dt2, kp_yaw, ki_yaw, kd_yaw, &pid_yaw);
    
    Serial.print("roll_angle_deg: ");
    Serial.print(roll_f * 180.0f / PI);
    Serial.print("pitch_angle_deg:") ; 
    Serial.print(pitch_f * 180.0f/PI) ;
    Serial.print("yaw_angle_deg: ") ;
    Serial.print(yaw_f * 180.0f/PI ) ; 
    Serial.print("Wz_f: ") ;
    Serial.print(wz_f) ; 
    Serial.print("Ywa_rate_ref : "); 
    Serial.println(yaw_rate_ref ) ;

  } 
}
