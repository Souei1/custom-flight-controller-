//--- read functions  
// Returns: true when read succeeded, false on timeout/short read
// Outputs:
//  ax,ay,az => accel in m/s^2 (bias-subtracted if accel_x_bias set)
//  wx,wy,wz => gyro in rad/s (bias-subtracted if gyro_*_bias set)
bool readMPU(float &ax, float &ay, float &az, float &wx, float &wy, float &wz) {
  Wire1.beginTransmission(ADDR_MPU);
  Wire1.write(0x3B); // starting register for accel
  Wire1.endTransmission(false);
  uint8_t count = Wire1.requestFrom((uint8_t)ADDR_MPU, (uint8_t)14);
  if (count < 14) return false;

  int16_t rawAx = (int16_t)(Wire1.read() << 8 | Wire1.read());
  int16_t rawAy = (int16_t)(Wire1.read() << 8 | Wire1.read());
  int16_t rawAz = (int16_t)(Wire1.read() << 8 | Wire1.read());
  int16_t rawTemp = (int16_t)(Wire1.read() << 8 | Wire1.read()); (void)rawTemp;
  int16_t rawGx = (int16_t)(Wire1.read() << 8 | Wire1.read());
  int16_t rawGy = (int16_t)(Wire1.read() << 8 | Wire1.read());
  int16_t rawGz = (int16_t)(Wire1.read() << 8 | Wire1.read());

  // scale accel: raw / (LSB per g) -> g -> *9.80665 -> m/s^2
  ax = ( (float)rawAx / ACCEL_SENS ) * G_TO_MS2;
  ay = ( (float)rawAy / ACCEL_SENS ) * G_TO_MS2;
  az = ( (float)rawAz / ACCEL_SENS ) * G_TO_MS2;
  
  // subtract any precomputed bias (in same units)
  ax -= accel_x_bias;
  ay -= accel_y_bias;
  az -= accel_z_bias;

  // scale gyro: raw / LSB -> deg/s -> *DEG2RAD -> rad/s
  wx = ( (float) rawGx / GYRO_SENS ) * DEG2RAD;
  wy = ( (float) rawGy / GYRO_SENS ) * DEG2RAD;
  wz = ( (float) rawGz / GYRO_SENS ) * DEG2RAD;

  wx -= gyro_x_bias;
  wy -= gyro_y_bias;
  wz -= gyro_z_bias;
   
  return true;
} 
bool readQMC5883L(float &mx, float &my, float &mz) {
  
  Wire1.beginTransmission(ADDR_MAG);
  Wire1.write(0x06);
  Wire1.endTransmission(false);
  Wire1.requestFrom((uint8_t)ADDR_MAG, (uint8_t)1);
  if (!Wire1.available()) return false;
  uint8_t status = Wire1.read();
  if (!(status & 0x01)) return false; 

  Wire1.beginTransmission(ADDR_MAG);
  Wire1.write(0x00); 
  Wire1.endTransmission(false);
  uint8_t count = Wire1.requestFrom((uint8_t)ADDR_MAG, (uint8_t)6);
  if (count < 6) return false;

  int16_t rawMx = (int16_t)(Wire1.read() | Wire1.read() << 8); // little-endian
  int16_t rawMy = (int16_t)(Wire1.read() | Wire1.read() << 8);
  int16_t rawMz = (int16_t)(Wire1.read() | Wire1.read() << 8);

  // Apply hard-iron + soft-iron correction
  mx = ((float)rawMx - mag_x_bias) * mag_x_scale;
  my = ((float)rawMy - mag_y_bias) * mag_y_scale;
  mz = ((float)rawMz - mag_z_bias) * mag_z_scale;

  return true;
}

//--- gyro bias 
void calibrateGyro(int samples=500, int delayMs=5) {
  long gx_sum=0, gy_sum=0, gz_sum=0;
  for (int i=0;i<samples;i++){
    float ax,ay,az, gx,gy,gz;
    if (!readMPU(ax,ay,az,gx,gy,gz)) { delay(5); --i; continue; }
    gx_sum += (long)(gx * 1e6f); // scale to preserve precision
    gy_sum += (long)(gy * 1e6f);
    gz_sum += (long)(gz * 1e6f);
    delay(delayMs);
  }
  gyro_x_bias = (float)gx_sum / (samples * 1e6f);
  gyro_y_bias = (float)gy_sum / (samples * 1e6f);
  gyro_z_bias = (float)gz_sum / (samples * 1e6f);

  Serial.print("Gyro biases (rad/s): ");
  Serial.print(gyro_x_bias,6); Serial.print(", ");
  Serial.print(gyro_y_bias,6); Serial.print(", ");
  Serial.println(gyro_z_bias,6);
}

//--- inner loop pid function 
float pid(float error, float dt, float kp, float ki,float kd,float *diff,PIDSTATE_RATE *state) {
  // prevent division by zero or very small dt
  if (dt <= 0.001f) {
    dt = 0.001f;
  }
  float derivative = (error - state->prev_error) / dt;
  state->d_f = (d_alpha * state->d_f) + ((1.0f - d_alpha) * derivative);
  // store raw derivative for Serial print/debug if needed
  *diff = derivative;
  // integral with anti-windup clamp
  state->integral += error * dt;
  state->integral = constrain(state->integral, -0.5f, 0.5f);
  // PID output = torque
  float output = kp * error + ki * state->integral + kd * state->d_f;
  state->prev_error = error;
  return output;
} 
//--- outer loop (angle control ) 
float pid_calc(float error, float angle, float rate, float dt,float kp, float ki, float kd, PIDSTATE_ANGLE *state){
  
  // integral only when angle error is reasonable
  if (fabsf(error) < 15.0f) {
    state->i += error * dt;
    state->i = constrain(state->i, -20.0f, 20.0f);
  }
  // derivative term uses gyro rate directly
  float d = rate;
  state->prev_error = error;
  // output is desired roll rate
  return kp * error + ki * state->i - kd * d;
}
//---inverse square root 
float invSqrt(float x) {
  float halfx = 0.5f * x;
  float y = x;
  long i = *(long*)&y;
  i = 0x5f3759df - (i>>1);
  y = *(float*)&i;
  y = y * (1.5f - (halfx * y * y));
  return y;
} 
//---Madgwick filter 
//--gradiant decent 
// Madgwick 9-axis gradient descent step
void MadgwickAHRSupdate(float gx, float gy, float gz,
                        float ax, float ay, float az,
                        float mx_in, float my_in, float mz_in,
                        float dt) {

  float recipNorm;
  float s0, s1, s2, s3;
  float qDot1, qDot2, qDot3, qDot4;
  float hx, hy;
  float _2q0mx, _2q0my, _2q0mz, _2q1mx;
  float _2bx, _2bz, _4bx, _4bz;
  float _2q0, _2q1, _2q2, _2q3;
  float _2q0q2, _2q2q3;
  float q0q0, q0q1, q0q2, q0q3, q1q1, q1q2, q1q3, q2q2, q2q3, q3q3;

  float q0 = q[0], q1 = q[1], q2 = q[2], q3 = q[3];

  // Use 6-axis fallback if magnetometer data is zero/invalid
  bool mag_valid = !((mx_in == 0.0f) && (my_in == 0.0f) && (mz_in == 0.0f));

  // Rate of change of quaternion from gyroscope
  qDot1 = 0.5f * (-q1*gx - q2*gy - q3*gz);
  qDot2 = 0.5f * ( q0*gx + q2*gz - q3*gy);
  qDot3 = 0.5f * ( q0*gy - q1*gz + q3*gx);
  qDot4 = 0.5f * ( q0*gz + q1*gy - q2*gx);

  if (!((ax == 0.0f) && (ay == 0.0f) && (az == 0.0f))) {

    // Normalize accel
    recipNorm = invSqrt(ax*ax + ay*ay + az*az);
    ax *= recipNorm; ay *= recipNorm; az *= recipNorm;

    if (mag_valid) {
      // Normalize mag
      recipNorm = invSqrt(mx_in*mx_in + my_in*my_in + mz_in*mz_in);
      mx_in *= recipNorm; my_in *= recipNorm; mz_in *= recipNorm;

      // Auxiliary variables
      _2q0mx = 2.0f * q0 * mx_in;
      _2q0my = 2.0f * q0 * my_in;
      _2q0mz = 2.0f * q0 * mz_in;
      _2q1mx = 2.0f * q1 * mx_in;
      _2q0   = 2.0f * q0;
      _2q1   = 2.0f * q1;
      _2q2   = 2.0f * q2;
      _2q3   = 2.0f * q3;
      q0q0   = q0*q0; q0q1 = q0*q1; q0q2 = q0*q2; q0q3 = q0*q3;
      q1q1   = q1*q1; q1q2 = q1*q2; q1q3 = q1*q3;
      q2q2   = q2*q2; q2q3 = q2*q3; q3q3 = q3*q3;

      // Reference direction of Earth's magnetic field
      hx = mx_in*(q0q0 + q1q1 - q2q2 - q3q3)
         + 2.0f*my_in*(q1q2 - q0q3)
         + 2.0f*mz_in*(q1q3 + q0q2);
      hy = 2.0f*mx_in*(q1q2 + q0q3)
         + my_in*(q0q0 - q1q1 + q2q2 - q3q3)
         + 2.0f*mz_in*(q2q3 - q0q1);
      _2bx = sqrtf(hx*hx + hy*hy);
      _2bz = -2.0f*mx_in*(q1q3 - q0q2)
             + 2.0f*my_in*(q2q3 + q0q1)
             + mz_in*(q0q0 - q1q1 - q2q2 + q3q3);
      _4bx = 2.0f * _2bx;
      _4bz = 2.0f * _2bz;

      // Gradient descent — 9-axis step
      s0 = -_2q2*(2.0f*(q1q3 - q0q2) - ax)
          + _2q1*(2.0f*(q0q1 + q2q3) - ay)
          - _2bz*q2*(_2bx*(0.5f - q2q2 - q3q3) + _2bz*(q1q3 - q0q2) - mx_in)
          + (-_2bx*q3 + _2bz*q1)*(_2bx*(q1q2 - q0q3) + _2bz*(q0q1 + q2q3) - my_in)
          + _2bx*q2*(_2bx*(q0q2 + q1q3) + _2bz*(0.5f - q1q1 - q2q2) - mz_in);

      s1 = _2q3*(2.0f*(q1q3 - q0q2) - ax)
         + _2q0*(2.0f*(q0q1 + q2q3) - ay)
         - 4.0f*q1*(1.0f - 2.0f*(q1q1 + q2q2) - az)  // ← az term added
         + _2bz*q3*(_2bx*(0.5f - q2q2 - q3q3) + _2bz*(q1q3 - q0q2) - mx_in)
         + (_2bx*q2 + _2bz*q0)*(_2bx*(q1q2 - q0q3) + _2bz*(q0q1 + q2q3) - my_in)
         + (_2bx*q3 - _4bz*q1)*(_2bx*(q0q2 + q1q3) + _2bz*(0.5f - q1q1 - q2q2) - mz_in);

      s2 = -_2q0*(2.0f*(q1q3 - q0q2) - ax)
         + _2q3*(2.0f*(q0q1 + q2q3) - ay)
         - 4.0f*q2*(1.0f - 2.0f*(q1q1 + q2q2) - az)
         + (-_4bx*q2 - _2bz*q0)*(_2bx*(0.5f - q2q2 - q3q3) + _2bz*(q1q3 - q0q2) - mx_in)
         + (_2bx*q1 + _2bz*q3)*(_2bx*(q1q2 - q0q3) + _2bz*(q0q1 + q2q3) - my_in)
         + (_2bx*q0 - _4bz*q2)*(_2bx*(q0q2 + q1q3) + _2bz*(0.5f - q1q1 - q2q2) - mz_in);

      s3 = _2q1*(2.0f*(q1q3 - q0q2) - ax)
         + _2q2*(2.0f*(q0q1 + q2q3) - ay)
         + (-_4bx*q3 + _2bz*q1)*(_2bx*(0.5f - q2q2 - q3q3) + _2bz*(q1q3 - q0q2) - mx_in)
         + (-_2bx*q0 + _2bz*q2)*(_2bx*(q1q2 - q0q3) + _2bz*(q0q1 + q2q3) - my_in)
         + _2bx*q1*(_2bx*(q0q2 + q1q3) + _2bz*(0.5f - q1q1 - q2q2) - mz_in);

    } else {
      // 6-axis fallback (same as your original)
      float _4q0 = 4.0f*q0, _4q1 = 4.0f*q1, _4q2 = 4.0f*q2;
      float _8q1 = 8.0f*q1, _8q2 = 8.0f*q2;
      _2q0 = 2.0f*q0; _2q1 = 2.0f*q1; _2q2 = 2.0f*q2; _2q3 = 2.0f*q3;
      q0q0 = q0*q0; q1q1 = q1*q1; q2q2 = q2*q2; q3q3 = q3*q3;

      s0 = _4q0*q2q2 + _2q2*ax + _4q0*q1q1 - _2q1*ay;
      s1 = _4q1*q3q3 - _2q3*ax + 4.0f*q0q0*q1 - _2q0*ay - _4q1 + _8q1*q1q1 + _8q1*q2q2 + _4q1*az;
      s2 = 4.0f*q0q0*q2 + _2q0*ax + _4q2*q3q3 - _2q3*ay - _4q2 + _8q2*q1q1 + _8q2*q2q2 + _4q2*az;
      s3 = 4.0f*q1q1*q3 - _2q1*ax + 4.0f*q2q2*q3 - _2q2*ay;
    }

    // Normalize gradient
    recipNorm = invSqrt(s0*s0 + s1*s1 + s2*s2 + s3*s3);
    s0 *= recipNorm; s1 *= recipNorm; s2 *= recipNorm; s3 *= recipNorm;

    qDot1 -= beta * s0;
    qDot2 -= beta * s1;
    qDot3 -= beta * s2;
    qDot4 -= beta * s3;
  }

  // Integrate
  q0 += qDot1 * dt;
  q1 += qDot2 * dt;
  q2 += qDot3 * dt;
  q3 += qDot4 * dt;

  recipNorm = invSqrt(q0*q0 + q1*q1 + q2*q2 + q3*q3);
  q[0] = q0 * recipNorm;
  q[1] = q1 * recipNorm;
  q[2] = q2 * recipNorm;
  q[3] = q3 * recipNorm;
}

//--- convert from q to euler 
void quatToFusedAngles(float q0, float q1, float q2, float q3,
                       float *fused_yaw, float *fused_roll, float *fused_pitch)
{
    // ---------- Fused Yaw ----------
    *fused_yaw = atan2f(
        2.0f * (q0*q3 + q1*q2),
        1.0f - 2.0f * (q2*q2 + q3*q3)
    );

    // ---------- Fused Pitch ----------
    float sp = 2.0f * (q0*q2 - q1*q3);
    if (sp > 1) sp = 1;
    if (sp < -1) sp = -1;
    *fused_pitch = asinf(sp);

    // ---------- Fused Roll ----------
    float sr = 2.0f * (q0*q1 + q2*q3);
    if (sr > 1) sr = 1;
    if (sr < -1) sr = -1;
    *fused_roll = asinf(sr);

    // ---------- Hemisphere ----------
    float h = q0*q0 + q3*q3 - (q1*q1 + q2*q2);

    if (h < 0) {
        *fused_pitch = copysignf(M_PI - fabsf(*fused_pitch), *fused_pitch);
        *fused_roll  = copysignf(M_PI - fabsf(*fused_roll),  *fused_roll );
    }
    
    yaw = *fused_yaw *180.0f / PI;
    roll = *fused_pitch* 180.0f / PI;
    pitch = *fused_roll * 180.0f / PI;
    if(roll>=175 ){
      roll = roll-175 ; 
    }else if(roll<=-175){
      roll = roll+175 ; 
    }
    if(pitch>=175 ){
      pitch = pitch-175 ; 
    }else if(pitch<=-175){
      pitch = pitch+175 ; 
    }
} 

double cubicInterp_C1(double T) {

  double PWM3 = 0.0;

  // c_1
  if( T <= 0.5){
    PWM3 =  200*T+ 1000;

  }else if (0.5 <=  T && T < 0.63){
    PWM3 = 153.846*T + 1023.076;

  }else if (0.63 <=  T && T < 0.75){
    PWM3 = 166.667*T + 1015;

  }else if (0.75 <=  T && T< 0.9){
    PWM3 = 133.333*T + 1040;

  }else if (0.9 <=  T && T < 1.02){
    PWM3 = 166.667*T + 1010;

  }else if (1.02 <=  T && T< 1.157){
    PWM3 = 145.985*T + 1031.094;

  }else if (1.157 <=  T && T< 1.27){
    PWM3 = 176.991*T + 995.221;

  }else if (1.27 <=  T  && T< 1.41){
    PWM3 = 142.857*T + 1038.571;

  }else if (1.41 <=  T && T< 1.55){
