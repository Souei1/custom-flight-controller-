//--- helper functions 
void normalizeVec3(float &x, float &y, float &z) {
  float n = sqrtf(x*x + y*y + z*z);
  if (n > 1e-8f) {
    x /= n; y /= n; z /= n;
  } else {
    // fallback to avoid division by zero: point Z-up
    x = 0.0f; y = 0.0f; z = 1.0f;
  }
} 
//--- sensor setup 
void setupMPU6050() {
  Wire1.begin();
  // wake up
  Wire1.beginTransmission(ADDR_MPU);
  Wire1.write(0x6B); Wire1.write(0x00); Wire1.endTransmission(); // wake
  // accel ±8g -> AFS_SEL = 2 -> 0x10 on ACCEL_CONFIG
  Wire1.beginTransmission(ADDR_MPU);
  Wire1.write(0x1C); Wire1.write(0x10); Wire1.endTransmission();
  // gyro ±2000 dps -> FS_SEL = 3 -> 0x18 on GYRO_CONFIG
  Wire1.beginTransmission(ADDR_MPU);
  Wire1.write(0x1B); Wire1.write(0x18); Wire1.endTransmission();
} 
