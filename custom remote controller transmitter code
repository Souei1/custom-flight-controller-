#include <SPI.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>

#define CE_PIN   9
#define CSN_PIN  10
#define switch_pin 2

LiquidCrystal_I2C lcd(0x27, 16, 2);

struct DataPackage {
  int16_t throttle;
  int16_t pitch;
  int16_t roll;
  int16_t yaw;
};

DataPackage myData;
byte address[5] = {'D','R','O','N','E'};
unsigned long lastLcdUpdate = 0;

// nRF24L01 helper functions

byte readRegister(byte reg) {
  digitalWrite(CSN_PIN, LOW);
  SPI.transfer(reg);
  byte val = SPI.transfer(0x00);
  digitalWrite(CSN_PIN, HIGH);
  return val;
}

void writeRegister(byte reg, byte val) {
  digitalWrite(CSN_PIN, LOW);
  SPI.transfer(0x20 | reg);
  SPI.transfer(val);
  digitalWrite(CSN_PIN, HIGH);
}

void writeRegisterMulti(byte reg, byte* buf, byte len) {
  digitalWrite(CSN_PIN, LOW);
  SPI.transfer(0x20 | reg);
  for (byte i = 0; i < len; i++) SPI.transfer(buf[i]);
  digitalWrite(CSN_PIN, HIGH);
}

void command(byte cmd) {
  digitalWrite(CSN_PIN, LOW);
  SPI.transfer(cmd);
  digitalWrite(CSN_PIN, HIGH);
}

void setup() {
  Serial.begin(115200);
  SPI.begin();

  pinMode(CE_PIN, OUTPUT);
  pinMode(CSN_PIN, OUTPUT);
  pinMode(switch_pin, INPUT_PULLUP);
  digitalWrite(CE_PIN, LOW);
  digitalWrite(CSN_PIN, HIGH);

  
  lcd.init();
  lcd.backlight();
  lcd.setCursor(0, 0);
  lcd.print("RC TX Ready...");
  delay(1000);
  lcd.clear();

 
  writeRegister(0x00, 0x0A);             
  delayMicroseconds(1500);
  writeRegister(0x01, 0x01);             
  writeRegister(0x03, 0x03);            
  writeRegister(0x04, 0x5F);             
  writeRegister(0x05, 110);              
  writeRegister(0x06, 0x07);             
  writeRegister(0x11, sizeof(myData));   

  writeRegisterMulti(0x10, address, 5);  
  writeRegisterMulti(0x0A, address, 5);  

  command(0xE1);                        
  writeRegister(0x07, 0x70);             
  digitalWrite(CE_PIN, HIGH);

  // Diagnostic
  byte cfg = readRegister(0x00);
  Serial.print("TX CONFIG: 0x"); Serial.println(cfg, HEX);
  if (cfg == 0x0A) Serial.println("nRF24 TX OK");
  else Serial.println("nRF24 TX ERROR – check wiring & 3.3V power!");

  Serial.println("Transmitter ready");
}

void loop() {
  bool isArmed = (digitalRead(switch_pin) == LOW);

  
  if (!isArmed) {
    myData.throttle = 1000;
  } else {
    int rawThrottle = analogRead(A0);
    if (rawThrottle <= 520) {
      myData.throttle = 1200;
    } else {
      myData.throttle = 1200 + ((1600.0 - 1200.0) / (1023.0 - 520.0)) * (rawThrottle - 520);
    }
  }

 
  int rawYaw = analogRead(A1);
  if (rawYaw > 490 && rawYaw < 510) {
    myData.yaw = 0;
  } else if (rawYaw >= 510) {
    myData.yaw = (360.0 / (1023.0 - 510.0)) * (rawYaw - 510);
  } else {
    myData.yaw = (-360.0 / 510.0) * (rawYaw - 510);
  }

  
  int rawPitch = analogRead(A2);
  if (rawPitch > 490 && rawPitch < 520) {
    myData.pitch = 0;
  } else if (rawPitch >= 520) {
    myData.pitch = (40.0 / (1023.0 - 520.0)) * (rawPitch - 520);
  } else {
    myData.pitch = (-40.0 / 520.0) * (rawPitch - 520);
  }

  
  int rawRoll = analogRead(A3);
  if (rawRoll > 490 && rawRoll < 516) {
    myData.roll = 0;
  } else if (rawRoll >= 516) {
    myData.roll = (40.0 / (1023.0 - 516.0)) * (rawRoll - 516);
  } else {
    myData.roll = (-40.0 / 516.0) * (rawRoll - 516);
  }

 
  digitalWrite(CSN_PIN, LOW);
  SPI.transfer(0xA0);                     
  byte* ptr = (byte*)&myData;
  for (int i = 0; i < sizeof(myData); i++) {
    SPI.transfer(ptr[i]);
  }
  digitalWrite(CSN_PIN, HIGH);

 
  digitalWrite(CE_PIN, HIGH);
  delayMicroseconds(15);
  digitalWrite(CE_PIN, LOW);

  
  unsigned long startTime = micros();
  byte status;
  do {
    status = readRegister(0x07);
  } while (!(status & 0x30) && (micros() - startTime < 5000));

  // Clear interrupt flags (TX_DS and MAX_RT)
  writeRegister(0x07, 0x70);

  // If MAX_RT occurred, flush TX FIFO
  if (status & 0x10) {
    command(0xE1);
  }

  
  if (millis() - lastLcdUpdate >= 200) {
    lastLcdUpdate = millis();
    lcd.setCursor(0, 0);
    if (isArmed) lcd.print("ARM ");
    else lcd.print("SAFE");
    lcd.print(" T:");
    lcd.print(myData.throttle);
    lcd.print("   ");

    lcd.setCursor(0, 1);
    lcd.print("Y:"); lcd.print(myData.yaw); lcd.print(" ");
    lcd.print("P:"); lcd.print(myData.pitch); lcd.print(" ");
    lcd.print("R:"); lcd.print(myData.roll);
    lcd.print("   ");
  }

  
  Serial.print("Armed:"); Serial.print(isArmed);
  Serial.print(" T:"); Serial.print(myData.throttle);
  Serial.print(" Y:"); Serial.print(myData.yaw);
  Serial.print(" P:"); Serial.print(myData.pitch);
  Serial.print(" R:"); Serial.println(myData.roll);

  delay(10); 
}
